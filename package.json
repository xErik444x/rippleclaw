{
  "name": "rippleclaw",
  "version": "0.1.0",
  "description": "Fast, autonomous AI agent infrastructure for low-power devices",
  "main": "dist/daemon.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/daemon.js",
    "cli": "node dist/daemon.js --channel cli",
    "debug:chat": "node scripts/debug-chat.js",
    "dev": "tsx --watch src/daemon.ts",
    "lint": "eslint .",
    "format": "prettier -w .",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "discord.js": "^14.16.3",
    "inquirer": "^9.3.7",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "eslint": "^9.19.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10"
}
