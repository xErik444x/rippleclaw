{
  "name": "rippleclaw",
  "version": "0.1.6",
  "description": "Fast, autonomous AI agent infrastructure for low-power devices",
  "author": "xErik444x",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xErik444x/rippleclaw.git"
  },
  "keywords": [
    "agent",
    "ai",
    "llm",
    "telegram",
    "discord",
    "bot",
    "raspberry-pi",
    "orange-pi",
    "automation"
  ],
  "main": "dist/daemon.js",
  "bin": "dist/daemon.js",
  "scripts": {
    "build": "esbuild src/daemon.ts --platform=node --format=cjs --outdir=dist --sourcemap --bundle",
    "build:tsc": "tsc -p tsconfig.json --incremental false",
    "build:bin": "npm run build && pkg . --targets node18-win-x64 --output bin/rippleclaw.exe --public --compress",
    "build:bin:linux-x64": "npm run build && pkg . --targets node18-linux-x64 --output bin/rippleclaw --public --compress",
    "build:bin:linux-arm64": "npm run build && pkg . --targets node18-linux-arm64 --output bin/rippleclaw --public --compress",
    "build:bin:win": "npm run build && pkg . --targets node18-win-x64 --output bin/rippleclaw.exe --public --compress",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/daemon.js",
    "cli": "node dist/daemon.js --channel cli",
    "debug:chat": "npm run build:tsc --silent && node scripts/debug-chat.js",
    "dev": "tsx --watch src/daemon.ts",
    "lint": "eslint .",
    "format": "prettier -w .",
    "test": "vitest run",
    "service:install": "bash scripts/install-service.sh",
    "service:uninstall": "bash scripts/uninstall-service.sh",
    "service:restart": "sudo systemctl restart rippleclaw"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "discord.js": "^14.16.3",
    "duckduckgo-images-api": "^1.0.5",
    "free-google-images": "^1.2.1",
    "inquirer": "^9.3.7",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "nodemailer": "^8.0.2",
    "sql.js": "^1.14.1",
    "undici": "^7.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/nodemailer": "^7.0.11",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.19.0",
    "pkg": "^5.8.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": "src/skills/**/*.md",
    "external": ["node:sqlite"]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.0.0"
}
